{
  "manifest_version": 3,
  "name": "Project Jarvis",
  "version": "2.0",
  "description": "Voice controlled AI agent.",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}